   "source": [
    "def shuffle_array(nums, n):\n",
    "    result = []\n",
    "    for index in range(n):\n",
    "        result.append(nums[index])\n",
    "        result.append(nums[index+n])\n",
    "        \n",
    "    return result "
   ]
