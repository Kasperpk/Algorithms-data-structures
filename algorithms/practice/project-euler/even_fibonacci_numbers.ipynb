   "source": [
    "def fibonacci(n):\n",
    "    if n <= 1:\n",
    "        return n\n",
    "\n",
    "    prev, curr = 0, 2\n",
    "    for _ in range(2, n+1):\n",
    "        next_even = 4 * curr + prev\n",
    "        prev, curr = curr, next_even\n",
    "\n",
    "    return curr"
   ]
  },
